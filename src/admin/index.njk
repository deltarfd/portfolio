<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <meta name="color-scheme" content="dark light">
  <title>Admin Dashboard · Delta Rahmat Fajar Delviansyah</title>

  <!-- Theme bootstrap: same default-dark logic as the public site. -->
  <script>
    (function () {
      try {
        var saved = localStorage.getItem('theme');
        var theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
      } catch (e) {}
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter:wght@300..600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles/tokens.css?v={{ buildTime }}">
  <link rel="stylesheet" href="/admin/admin.css?v={{ buildTime }}">
  <link rel="icon" href="/favicon.png">
</head>
<body>
  <header class="adm-top">
    <a class="adm-wordmark" href="/" target="_blank" rel="noopener" title="View site">DELTA<span>· Admin Dashboard</span></a>
    <div class="adm-top__actions">
      <span class="adm-status" id="adm-status" role="status" aria-live="polite"></span>
      <button class="adm-theme" id="adm-theme" type="button" aria-label="Toggle theme" title="Toggle light / dark theme">
        <svg class="adm-theme__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
        <svg class="adm-theme__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
    </div>
  </header>

  <div class="adm-shell">
    <nav class="adm-side" id="adm-side" aria-label="Collections">
      <p class="adm-side__title">Collections</p>
      <ul class="adm-nav" id="adm-nav" role="list"></ul>
    </nav>

    <main class="adm-main" id="adm-main" tabindex="-1">
      <p class="adm-loading">Loading…</p>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js" crossorigin="anonymous"></script>
  <script type="module" src="/admin/admin.js?v={{ buildTime }}"></script>
</body>
</html>
